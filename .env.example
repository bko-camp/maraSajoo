# Google AI (API 라우트 및 루트의 test-*.js 스크립트)
GEMINI_API_KEY=

# Toss 결제 위젯 — NEXT_PUBLIC_* 는 브라우저 번들에 포함됩니다. 위젯용 클라이언트 키만 사용하세요.
NEXT_PUBLIC_TOSS_WIDGET_CLIENT_KEY=
NEXT_PUBLIC_TOSS_CUSTOMER_KEY=
NEXT_PUBLIC_TOSS_PAYMENT_AMOUNT=990
NEXT_PUBLIC_TOSS_ORDER_NAME=마라맛 사주 폭탄 제거 2026
NEXT_PUBLIC_TOSS_ORDER_ID_PREFIX=MARA_
NEXT_PUBLIC_TOSS_AGREEMENT_VARIANT_KEY=AGREEMENT

# 결제 승인(confirm) 등 서버 API 호출 시만 사용. 브라우저에 노출하지 마세요.
TOSS_PAYMENTS_SECRET_KEY=

# NextAuth (Auth.js v5) — Google / Kakao 소셜 로그인
# AUTH_SECRET: openssl rand -base64 32 로 생성
# AUTH_URL은 설정하지 않음 — trustHost가 접속 URL을 자동 사용
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=
